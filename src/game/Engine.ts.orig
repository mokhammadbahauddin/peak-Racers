import * as THREE from 'three';
import * as CANNON from 'cannon-es';
import { RenderPipeline } from './RenderPipeline';
import { TrackGenerator } from './TrackGenerator';
import { InputManager } from './InputManager';
import { createCarModel } from './CarGenerator';
import { CameraController } from './CameraController';
import { AiManager } from './AiManager';
import { ItemManager } from './ItemManager';
import { JuiceManager } from './JuiceManager';
import { AudioManager } from './AudioManager';
import { GameDataManager } from './GameData';
import { TRACK_REGISTRY } from './tracks/TrackRegistry';
import { ArcadeVehicle } from './physics/ArcadeVehicle';
import { PhysicsConfig } from './physics/PhysicsConfig';
import { useHudStore } from './stores/useHudStore';
import { generateNetworkManager } from './NetworkManager';

export type GameState = 'intro' | 'countdown' | 'racing' | 'finished' | 'podium';

export class Engine {
  pipeline: RenderPipeline;
  track: TrackGenerator;
  input: InputManager;
  juice: JuiceManager;
  audio: AudioManager;
  container: HTMLElement;
  onFinish: (rank: number, timeMs: number, bestLapMs?: number) => void;

  world!: CANNON.World;
  playerVehicle!: ArcadeVehicle;
  chassisBody!: CANNON.Body;
  isPaused: boolean = false;
  camera: CameraController;

  trackCurvePts: {p: THREE.Vector3, t: number}[] = [];

  gameState: GameState = 'intro';
  stateTimer: number = 1.0;
  raceTimeMs: number = 0;
  finalRank: number = 1;

  driftTimer: number = 0;
  boostAmount: number = 100; // 0 to 100 max
  autoBoostTimer: number = 0;

  playerCar: THREE.Group;
  aiManager: AiManager;
  itemManager: ItemManager;
  networkManager: any;
  remoteCarMeshes: Record<string, THREE.Group> = {};

  playerT = 0;
  playerOffX = 0;
  speed = 0;
  maxSpeed = 120;
  currentLap = 1;
  totalLaps = 3;
  lapTimer = 0;
  bestLapMs = Infinity;

  reqId: number | null = null;
  lastTime: number = 0;
  up = new THREE.Vector3(0, 1, 0);

  private speedMult: number = 1.0;
  private handlingMult: number = 1.0;
  private armorMult: number = 1.0;

  // Temp vectors to eliminate GC lag
  private _t1 = new THREE.Vector3();
  private _t2 = new THREE.Vector3();
  private _t3 = new THREE.Vector3();
  private _t4 = new THREE.Vector3();
  private _v1 = new CANNON.Vec3();
  private _v2 = new CANNON.Vec3();
  private _up = new THREE.Vector3(0, 1, 0);
  private _forwardLocal = new THREE.Vector3();

  // Data pools
  private _scoresCache: {isPlayer: boolean, score: number}[] = [];
  private _aiTsCache: number[] = [];

  constructor(
      container: HTMLElement,
      onFinish: (rank: number, timeMs: number, bestLapMs?: number) => void
  ) {
    this.container = container;
    this.onFinish = onFinish;

    let activeWorld = 'soft_sands';
    let activeTrackId = 'sands_1';
    try {
      if (GameDataManager) {
        activeWorld = GameDataManager.getInstance().getData().activeWorld || 'soft_sands';
        activeTrackId = GameDataManager.getInstance().getData().activeTrack || 'sands_1';
      }
    } catch (e) {}

    let trackDef = TRACK_REGISTRY[activeWorld]?.find(t => t.id === activeTrackId) || TRACK_REGISTRY['soft_sands'][0];
    this.totalLaps = trackDef.laps || 3;

    let envData = { sky: trackDef.environment.skyColor, fogNear: trackDef.environment.fogNear, fogFar: trackDef.environment.fogFar };

    this.pipeline = new RenderPipeline(container, envData);
    this.audio = new AudioManager(this.pipeline.camera);
    this.input = new InputManager();
    this.camera = new CameraController(this.pipeline.camera, this.input);
    this.track = new TrackGenerator(this.pipeline.scene, trackDef);
    this.juice = new JuiceManager(this.pipeline.scene);
    this.itemManager = new ItemManager(this.track, this.audio, this.juice, this.pipeline.scene);

    const curveSamples = 400;
    for (let i = 0; i <= curveSamples; i++) {
        const t = i / curveSamples;
        this.trackCurvePts.push({ p: this.track.curve.getPointAt(t), t });
    }

    let carColor = 0xffadbc;
    let carType: 'cruiser' | 'sprinter' | 'tank' = 'cruiser';
    try {
      const data = GameDataManager.getInstance().getData();
      carColor = data.activeColor;
      carType = data.activeCarType;

      // Legacy stat levels still contribute
      this.speedMult = 1.0 + (data.stats.speedLevel - 1) * 0.1;
      this.handlingMult = 1.0 + (data.stats.handlingLevel - 1) * 0.15;
      this.armorMult = 1.0 + (data.stats.armorLevel - 1) * 0.25;

      // Vehicle upgrade bonuses (turbo → speed, tires → handling, aero → acceleration)
      const vehicleId = data.activeVehicleId || 'bubblegum_cruiser';
      const upgrades = data.vehicleUpgrades?.[vehicleId];
      if (upgrades) {
        this.speedMult += (upgrades.turbo || 0) * 0.05;     // +5% per turbo level
        this.handlingMult += (upgrades.tires || 0) * 0.06;   // +6% per tire level
        // aero boosts acceleration (handled via speedMult for simplicity)
        this.speedMult += (upgrades.aero || 0) * 0.03;
      }

      // Apply base class multipliers
      if (carType === 'sprinter') {
         this.maxSpeed = PhysicsConfig.topSpeedA;
         this.speedMult *= 1.2;
         this.handlingMult *= 1.1;
         this.armorMult *= 0.8;
      } else if (carType === 'tank') {
         this.maxSpeed = PhysicsConfig.topSpeedC;
         this.speedMult *= 0.8;
         this.handlingMult *= 0.8;
         this.armorMult *= 1.5;
      } else {
         this.maxSpeed = PhysicsConfig.topSpeedB;
      }

      // Character trait modifiers
      const characterId = data.activeCharacter || 'cat';
      if (characterId === 'bunny') {
        // Speedster: faster overall
        this.speedMult *= 1.08;
        this.armorMult *= 0.85;
      } else if (characterId === 'frog') {
        // Drift Master: better handling
        this.handlingMult *= 1.12;
      } else if (characterId === 'bear') {
        // Tank: heavier, more armor
        this.armorMult *= 1.3;
        this.speedMult *= 0.95;
      }
      // cat = All-Rounder, no adjustments
    } catch(e) {}

    this.playerCar = createCarModel(carColor, carType);
    this.pipeline.scene.add(this.playerCar);

    this.aiManager = new AiManager();

    this.networkManager = generateNetworkManager();
    this.networkManager.connect(carType);

    const initCamPt = this.track.curve.getPointAt(0);
    const initCamTan = this.track.curve.getTangentAt(0).normalize();
    this.camera.initIntro(initCamPt, initCamTan);

    this.initPhysics(initCamPt, initCamTan);

    this.handleResize = this.handleResize.bind(this);
    window.addEventListener('resize', this.handleResize);

    this.lastTime = performance.now();
    this.animate = this.animate.bind(this);
    this.reqId = requestAnimationFrame(this.animate);
  }

  private initPhysics(startPt: THREE.Vector3, startTan: THREE.Vector3) {
    this.world = new CANNON.World();
    this.world.gravity.set(0, -30, 0);
    this.world.allowSleep = false;
    this.world.broadphase = new CANNON.SAPBroadphase(this.world);
    this.world.defaultContactMaterial.friction = 0.8;

    // Track Physics
    const trimeshShape = new CANNON.Trimesh(this.track.trackPositions, this.track.trackIndices);
    const trackBody = new CANNON.Body({ mass: 0, collisionFilterGroup: 2 });
    trackBody.addShape(trimeshShape);
    this.world.addBody(trackBody);

    // Bounding planes (so car doesn't fall forever)
    const groundShape = new CANNON.Plane();
    const groundBody = new CANNON.Body({ mass: 0, collisionFilterGroup: 2 });
    groundBody.addShape(groundShape);
    groundBody.quaternion.setFromEuler(-Math.PI / 2, 0, 0);
    groundBody.position.y = -2;
    this.world.addBody(groundBody);

    const groundGeo = new THREE.PlaneGeometry(8000, 8000);
    const groundMat = new THREE.MeshStandardMaterial({ color: this.track.trackData.colors.base, roughness: 1.0, flatShading: true });
    const groundMesh = new THREE.Mesh(groundGeo, groundMat);
    groundMesh.rotation.x = -Math.PI / 2;
    groundMesh.position.y = -2;
    groundMesh.receiveShadow = true;
    this.pipeline.scene.add(groundMesh);

    // Track Scenery collision
    this.track.physicsProps.forEach(prop => {
        const body = new CANNON.Body({ mass: 0, collisionFilterGroup: 2 }); // static
        let shape;

        if (prop.type === 'barrier') {
            shape = new CANNON.Box(new CANNON.Vec3(4, 1.5, 1.5)); // Cylinder rotated Z is horizontal
        } else if (prop.type === 'tree') {
            shape = new CANNON.Box(new CANNON.Vec3(2, 6, 2)); // Trees
        } else if (prop.type === 'sign') {
            shape = new CANNON.Box(new CANNON.Vec3(7, 7, 1));
        } else { // flag
            shape = new CANNON.Cylinder(0.5, 0.5, 12, 8);
        }

        body.addShape(shape as any);
        body.position.copy(prop.position as any);
        body.quaternion.copy(prop.quaternion as any);
        this.world.addBody(body);
    });

    // Player Car Chassis
    const faceAngle = Math.atan2(startTan.x, startTan.z) + Math.PI;

    this.playerVehicle = new ArcadeVehicle(this.world, this.playerCar, startPt, faceAngle, this.speedMult, this.armorMult, this.handlingMult, this.maxSpeed);
    this.chassisBody = this.playerVehicle.body;

    this.chassisBody.addEventListener("collide", (e: any) => {
        // Simple wall collision check (normal is mostly horizontal)
        if (Math.abs(e.contact.ni.y) < 0.5) {
            // Apply bounce stun
            if (this.stunTimer <= 0) {
                this.stunTimer = PhysicsConfig.wallBounceStun;
                this.chassisBody.velocity.scale(1.0 - PhysicsConfig.wallBounceSpeed, this.chassisBody.velocity);
                this.audio.playCrash();
                this.camera.addShake(0.6);
                this.juice.addImpact(this.playerCar.position, 0xffffff);
            }
        }
    });

    // AI Cars Physics
    this.aiManager.init(this.pipeline.scene, this.world, this.track, this.trackCurvePts);
  }

  private handleResize() {
    this.pipeline.resize();
  }

  public simulateInput(key: string, state: boolean) {
    if (this.input) {
       this.input.simulateKey(key, state);
    }
  }

  public togglePause(paused: boolean) {
    this.isPaused = paused;
    this.lastTime = performance.now();
  }

  private wasDrifting = false;
  private driftCooldownTimer = 0;
  private stunTimer = 0;

  private animate() {
    const now = performance.now();
    const dt = Math.min((now - this.lastTime) / 1000, 0.1);
    this.lastTime = now;

    this.input.update(dt);

    if (this.isPaused) {
      this.reqId = requestAnimationFrame(this.animate);
      return;
    }

    if (this.driftCooldownTimer > 0) {
      this.driftCooldownTimer -= dt;
    }

    // Check progress by finding closest point on track curve
    let minDist = Infinity;
    let closestT = this.playerT;
    for (let i = 0; i < this.trackCurvePts.length; i++) {
       const pt = this.trackCurvePts[i];
       const d = pt.p.distanceToSquared(this.playerCar.position);
       if(d < minDist) {
          minDist = d;
          closestT = pt.t;
       }
    }
    minDist = Math.sqrt(minDist); // Convert back to actual distance after loop

    const { keys } = this.input;

    this.world.step(1/60, dt, 3);

    // Apply speed-based downforce to keep it grounded
    const downforceMagnitude = Math.abs(this.speed) * 50;
    this.chassisBody.wakeUp();
    this._v1.set(0, -downforceMagnitude, 0);
    this._v2.set(0, 0, 0);
    this.chassisBody.applyLocalForce(this._v1, this._v2);

    // Remove apply downforce to AI cars

    const maxSteerVal = 0.45 * this.handlingMult; // modified by handling level
    let maxForce = 9000 * this.speedMult;      // increased for higher mass
    const brakeForce = 120;

    if (this.autoBoostTimer > 0) {
       this.autoBoostTimer -= dt;
    }

    // Boost decay idle
    if (!this.input.isBoosting() && this.boostAmount > 0 && this.autoBoostTimer <= 0) {
       this.boostAmount -= dt * PhysicsConfig.boostDecay;
       if (this.boostAmount < 0) this.boostAmount = 0;
    }

    let isBoosting = (this.input.isBoosting() && this.boostAmount > 0) || this.autoBoostTimer > 0;
    if (isBoosting) {
       maxForce = 9000 * this.speedMult * PhysicsConfig.boostSpeedMult; // Apply GDD boost speed mult
       if (this.input.isBoosting() && this.boostAmount > 0) {
           this.boostAmount -= dt * (100 / PhysicsConfig.boostDuration); // Deplete manual boost over configured duration
           if (this.boostAmount < 0) this.boostAmount = 0;
       }
    }

    let engineForce = 0;
    let braking = 0;
    let vehicleSteer = 0;
    let isDrifting = false;
    let isOffroad = false;

    // Check Surface State
    if (minDist > this.track.roadWidth * 1.05) {
       isOffroad = true;
       // Off-road greatly bounds max force and speed
       maxForce = 9000 * this.speedMult * (1.0 - PhysicsConfig.offTrackPenalty);
       if (this.speed > 40) {
           braking = 50; // drag from grass/sand
       }
       if (isBoosting) {
           this.boostAmount -= dt * (100 / PhysicsConfig.boostDuration) * 2; // depletes twice as fast off-road
           maxForce = 9000 * this.speedMult * (1.0 - PhysicsConfig.offTrackPenalty) * PhysicsConfig.boostSpeedMult;
       }
       // Tire scrub color could change, but for now we just slow them down and emit particles
       if (Math.abs(this.speed) > 20 && Math.random() < 0.2) {
           this._t1.copy(this.playerCar.position);
           this.juice.addExhaust(this._t1, false);
       }
    }

    if (this.gameState === 'intro' || this.gameState === 'countdown' || this.gameState === 'finished') {
       braking = brakeForce;
    } else {
        // Lakitu style respawn (GDD Section 13)
        if (this.input.isReset() || this.chassisBody.position.y < -5) {
            const resetPt = this.track.curve.getPointAt(this.playerT);
            const resetTan = this.track.curve.getTangentAt(this.playerT).normalize();
            const resetAngle = Math.atan2(resetTan.x, resetTan.z) + Math.PI;

            this.chassisBody.position.set(resetPt.x, resetPt.y + 4, resetPt.z);
            this.chassisBody.quaternion.setFromEuler(0, resetAngle, 0);

            // "No reset to zero velocity"
            this.chassisBody.velocity.set(resetTan.x * -40, 0, resetTan.z * -40);
            this.chassisBody.angularVelocity.set(0,0,0);
        }

       const gearUpPressed = this.input.isGearUp();
       const gearDownPressed = this.input.isGearDown();

       const steer = this.input.getSteer(dt);
       if (Math.abs(steer) > 0.05) vehicleSteer = steer * maxSteerVal;

       // Physics handles collisions via the Trimesh now, no artificial constraints.
    }

    // Item usage is handled by ItemManager

    if (this.input.isDrifting()) {
        if (!(this as any).wasDriftingActive && Math.abs(this.speed) > 40 && Math.abs(this.input.getSteer()) > 0.1) {
            (this as any).wasDriftingActive = true;
        }
    } else {
        (this as any).wasDriftingActive = false;
    }

    if ((this as any).wasDriftingActive) {
       isDrifting = true;
       vehicleSteer *= 1.8; // Snappier turning while drifting
    }

    // Default maxSpeed multiplier applied during boost
    if (isBoosting) this.playerVehicle.speedMult = this.speedMult * PhysicsConfig.boostSpeedMult;
    else if (isOffroad) this.playerVehicle.speedMult = this.speedMult * (1.0 - PhysicsConfig.offTrackPenalty);
    else if (isDrifting) this.playerVehicle.speedMult = this.speedMult * PhysicsConfig.driftSpeedMult;
    else this.playerVehicle.speedMult = this.speedMult;

    if (this.stunTimer > 0) {
       this.stunTimer -= dt;
    }

    let gas = this.input.getGas();
    if (this.stunTimer > 0) {
       gas = 0;
       braking = 50;
       vehicleSteer = 0;
    }

    const gearUp = this.input.isGearUp() && !(this as any).wasGearUp;
    const gearDown = this.input.isGearDown() && !(this as any).wasGearDown;
    (this as any).wasGearUp = this.input.isGearUp();
    (this as any).wasGearDown = this.input.isGearDown();

    this.playerVehicle.update(gas, vehicleSteer, braking, gearUp, gearDown, isDrifting, dt);
    this.playerVehicle.render(dt);

    this._forwardLocal.set(0, 0, -1).applyQuaternion(this.playerCar.quaternion);

    // Compute player speed roughly (km/h)
    const currentVel = this.chassisBody.velocity.length();
    this.speed = currentVel * 3.6;

    // Drifting logic
    if (isDrifting && !(this as any).wasDrifting) {
       this.playerVehicle.hop();
       this.driftTimer = 0;
    }

    if (isDrifting) {
       // Accumulate drift charge based on steer intensity
       const steerIntensity = Math.abs(vehicleSteer) / maxSteerVal;
       this.driftTimer += dt * (0.5 + steerIntensity * 0.5);

       // Boost charge rate: +3% boost/s while drifting (GDD Physics)
       this.boostAmount = Math.min(PhysicsConfig.boostCapacity, this.boostAmount + (dt * PhysicsConfig.boostChargeRate));

       const leftWheelPos = this._t1.set(-0.8, -0.5, -0.8).applyQuaternion(this.playerCar.quaternion).add(this.playerCar.position);
       const rightWheelPos = this._t2.set(0.8, -0.5, -0.8).applyQuaternion(this.playerCar.quaternion).add(this.playerCar.position);

       this.juice.addScrub(leftWheelPos, this.playerCar.quaternion);
       this.juice.addScrub(rightWheelPos, this.playerCar.quaternion);

       let sparkColor = -1;
       if (this.driftTimer > PhysicsConfig.miniTurboThreshold * 2.0) {
           sparkColor = 0x8800ff; // Purple (Super Mini-Turbo)
       } else if (this.driftTimer > PhysicsConfig.miniTurboThreshold) {
           sparkColor = 0xff8800; // Orange (Mini-Turbo)
       } else if (this.driftTimer > PhysicsConfig.miniTurboThreshold * 0.4) {
           sparkColor = 0x0088ff; // Blue (Small-Turbo)
       }

       if (sparkColor !== -1 && Math.random() < 0.3) {
           this.juice.addSparks(leftWheelPos, sparkColor);
           this.juice.addSparks(rightWheelPos, sparkColor);
       }

       // Play audio cue when crossing thresholds
       const prevTimer = this.driftTimer - dt * (0.5 + steerIntensity * 0.5);
       if ((prevTimer <= PhysicsConfig.miniTurboThreshold * 0.4 && this.driftTimer > PhysicsConfig.miniTurboThreshold * 0.4) ||
           (prevTimer <= PhysicsConfig.miniTurboThreshold && this.driftTimer > PhysicsConfig.miniTurboThreshold) ||
           (prevTimer <= PhysicsConfig.miniTurboThreshold * 2.0 && this.driftTimer > PhysicsConfig.miniTurboThreshold * 2.0)) {
           this.audio.playPickup();
       }

       const exhaustPos = this._t3.copy(this._forwardLocal).multiplyScalar(-2.5).add(this.playerCar.position);
       this.juice.addExhaust(exhaustPos, false);
    } else {
       if ((this as any).wasDrifting) {
           // Release drift boost if held long enough (tiered Mini-Turbo)
           let boostDuration = 0;
           if (this.driftTimer > PhysicsConfig.miniTurboThreshold * 2.0) {
               boostDuration = PhysicsConfig.miniTurboDuration * 2.5;  // Purple Turbo (seconds)
           } else if (this.driftTimer > PhysicsConfig.miniTurboThreshold) {
               boostDuration = PhysicsConfig.miniTurboDuration;  // Orange Turbo (seconds)
           } else if (this.driftTimer > PhysicsConfig.miniTurboThreshold * 0.4) {
               boostDuration = PhysicsConfig.miniTurboDuration * 0.5;  // Blue Turbo (seconds)
           }

           if (boostDuration > 0) {
               this.autoBoostTimer = boostDuration;
               this.driftCooldownTimer = 0.5; // Cooldown
               this.audio.playPickup();
               // Extra initial hop/shake
               this.camera.addShake(0.4);
               this.playerVehicle.hop();
           }
       }
       this.driftTimer = 0;
    }
    (this as any).wasDrifting = isDrifting;

    if (isBoosting && Math.abs(this.speed) > 20) {
       this._t1.copy(this._forwardLocal).multiplyScalar(-2.5).add(this.playerCar.position);
       this.juice.addExhaust(this._t1, true);
       this.camera.addShake(0.4);
    }

    // Impact Shake detection
    const velDiff = Math.abs(currentVel - (this as any).lastVel || 0);
    (this as any).lastVel = currentVel;
    if (velDiff > 8) {
        this.camera.addCumulativeShake(velDiff * 0.1);
        this.audio.playCrash();
    }
    this.juice.update(dt);

    const pVec = new THREE.Vector3(this.playerVehicle.body.velocity.x, this.playerVehicle.body.velocity.y, this.playerVehicle.body.velocity.z);

    // Check Item Boxes & Usage
    this.itemManager.update(dt, now, this.playerCar.position, pVec, this.input, (dur) => {
        this.autoBoostTimer = Math.max(this.autoBoostTimer, dur);
    }, (amount) => {
        this.boostAmount = Math.min(PhysicsConfig.boostCapacity, this.boostAmount + amount);
    }, () => {
        // Spinout logic for player
        this.stunTimer = PhysicsConfig.wallBounceStun;
        this.camera.addShake(1.0);
        this.audio.playCrash();
        // Halve velocity
        this.playerVehicle.body.velocity.scale(0.5, this.playerVehicle.body.velocity);
        // Force angular velocity
        this.playerVehicle.body.angularVelocity.set(0, 10, 0);
    }, this.aiManager.aiCars);

    // Out of bounds detection & Manual Reset
    if (minDist > 120 || this.chassisBody.position.y < -5 || this.input.isReset()) {
         // Auto Reset
         const resetPt = this.track.curve.getPointAt(this.playerT);
         const resetTan = this.track.curve.getTangentAt(this.playerT).normalize();
         const resetAngle = Math.atan2(resetTan.x, resetTan.z) + Math.PI;

         this.chassisBody.position.set(resetPt.x, resetPt.y + 2, resetPt.z);
         this.chassisBody.quaternion.setFromEuler(0, resetAngle, 0);
         this.chassisBody.velocity.set(0,0,0);
         this.chassisBody.angularVelocity.set(0,0,0);

         this.playerCar.position.copy(this.chassisBody.position as any);
         this.playerCar.quaternion.copy(this.chassisBody.quaternion as any);

         minDist = 0; // Prevent infinite loop of resetting
         closestT = this.playerT;
    }

    const getScore = (t: number, lap: number) => lap * 1000 + t;

    // Sort array in place or rebuild without generating new objects
    this._scoresCache.length = 0;
    for (let i = 0; i < this.aiManager.aiCars.length; i++) {
        this._scoresCache.push({ isPlayer: false, score: getScore(this.aiManager.aiCars[i].t, this.aiManager.aiCars[i].lap) });
    }
    this._scoresCache.push({ isPlayer: true, score: getScore(this.playerT, this.currentLap) });
    this._scoresCache.sort((a,b) => b.score - a.score);
    const pRank = this._scoresCache.findIndex(s => s.isPlayer) + 1;

    // Lap boundary detection
    if (this.gameState === 'racing') {
        this.lapTimer += dt * 1000;

        if (this.playerT > 0.8 && closestT < 0.2 && minDist < 60) {
          if (this.lapTimer < this.bestLapMs) {
              this.bestLapMs = this.lapTimer;
          }
          this.lapTimer = 0;
          this.currentLap++;
          if (this.currentLap > this.totalLaps) {
              this.gameState = 'finished';
              this.finalRank = pRank;
              this.stateTimer = 0;
          }
        } else if (this.playerT < 0.2 && closestT > 0.8 && minDist < 60) {
          this.currentLap = Math.max(1, this.currentLap - 1);
        }
    }
    if (minDist < 60) this.playerT = closestT;

    const pPt = this.track.curve.getPointAt(this.playerT);
    const pTan = this.track.curve.getTangentAt(this.playerT).normalize();

    // Camera follow (chase cam)
    const actualPos = this.playerCar.position;

    // Instead of locking to pTan, look at where physical car is facing
    this.camera.update(this.gameState, dt, actualPos, this.playerCar.quaternion, this.speed, this.maxSpeed, isDrifting, this.stateTimer);

    // Handle Game States Logic
    if (this.gameState === 'intro') {
        this.stateTimer -= dt;
        if (this.stateTimer <= 0) {
            this.gameState = 'countdown';
            this.stateTimer = 4.0; // 3,2,1,GO
        }
    } else if (this.gameState === 'countdown') {
        this.stateTimer -= dt;
        if (this.stateTimer <= 0) {
            this.gameState = 'racing';
        }
    } else if (this.gameState === 'racing') {
        this.raceTimeMs += dt * 1000;
    } else if (this.gameState === 'finished') {
        this.stateTimer += dt;
        if (this.stateTimer > 4.0) {
            this.gameState = 'podium';
            this.stateTimer = 0;
            // Stop cars to emulate podium parking
            this.chassisBody.velocity.set(0,0,0);
            this.chassisBody.angularVelocity.set(0,0,0);

            // Save race data
            let activeTrackId = GameDataManager?.getInstance()?.getData()?.activeTrack || 'sands_1';
            GameDataManager?.getInstance()?.saveRaceRecord(activeTrackId, this.raceTimeMs, this.bestLapMs !== Infinity ? this.bestLapMs : undefined);
        }
    } else if (this.gameState === 'podium') {
        this.stateTimer += dt;
        if (this.stateTimer > 3.0) {
            this.onFinish(this.finalRank, this.raceTimeMs, this.bestLapMs !== Infinity ? this.bestLapMs : undefined);
            return;
        }
    }

    this.pipeline.dirLight.position.set(actualPos.x + 80, actualPos.y + 120, actualPos.z + 20);
    this.pipeline.dirLight.target.position.copy(actualPos);
    this.pipeline.dirLight.target.updateMatrixWorld();

    this.track.animateScenery(now, dt);

    this.aiManager.update(dt, this.track, actualPos, pRank, this.gameState, this.playerT);
    this._aiTsCache = this.aiManager.getTs();

    // Multiplayer Networking
    if (this.networkManager) {
       this.networkManager.sendUpdate(this.playerCar.position, this.playerCar.quaternion);

       // Sync remote cars
       for (const id in this.networkManager.remotePlayers) {
          const rp = this.networkManager.remotePlayers[id];
          if (!this.remoteCarMeshes[id]) {
              // Spawn remote car (assume random color or cyan for now)
              this.remoteCarMeshes[id] = createCarModel(0x00ffff, rp.carType as any);
              this.pipeline.scene.add(this.remoteCarMeshes[id]);
          }

          // Smoother interpolations in a real game, right now snapping position
          this.remoteCarMeshes[id].position.copy(rp.position);
          this.remoteCarMeshes[id].quaternion.copy(rp.rotation);
       }

       // Remove disconnected cars
       for (const id in this.remoteCarMeshes) {
          if (!this.networkManager.remotePlayers[id]) {
              this.pipeline.scene.remove(this.remoteCarMeshes[id]);
              delete this.remoteCarMeshes[id];
          }
       }
    }

    const rpm = this.playerVehicle.rpm;
    const showRedline = rpm > 0.95 && this.speed > 10;

    useHudStore.getState().setHudData({
      speed: this.speed,
      lap: this.currentLap,
      rank: pRank,
      maxSpeed: this.maxSpeed,
      gear: this.playerVehicle.currentGear,
      rpm: rpm,
      showRedline: showRedline,
      gameState: this.gameState,
      timer: this.stateTimer,
      boost: this.boostAmount,
      playerT: this.playerT,
      aiTs: this._aiTsCache
    });

    this.audio.update(this.speed, this.maxSpeed, isDrifting, isBoosting, dt);

    this.pipeline.render();
    this.reqId = requestAnimationFrame(this.animate);
  }

  public dispose() {
     if (this.networkManager) {
        this.networkManager.disconnect();
     }
     if (this.reqId) cancelAnimationFrame(this.reqId);
     window.removeEventListener('resize', this.handleResize);
     this.input.dispose();
     this.audio.dispose();
     this.pipeline.dispose();
     if(this.container.contains(this.pipeline.renderer.domElement)) {
         this.container.removeChild(this.pipeline.renderer.domElement);
     }
  }
}
