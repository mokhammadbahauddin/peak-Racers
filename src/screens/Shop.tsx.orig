import React, { useState, useEffect } from 'react';
import { motion } from 'motion/react';
import { ChevronLeft, Coins, Gem, Star, Sparkles, ShoppingBag } from 'lucide-react';
import { GameDataManager } from '../game/GameData';
import { VEHICLES, Vehicle } from '../game/VehicleData';

interface ShopItem {
  id: string;
  name: string;
  description: string;
  price: number;
  currency: 'coins' | 'gems';
  rarity: 'common' | 'rare' | 'epic' | 'legendary';
  type: 'vehicle' | 'skin' | 'trail';
  emoji: string;
}

const SHOP_ITEMS: ShopItem[] = [
  // Vehicles
  ...VEHICLES.filter(v => v.unlockCost > 0).map(v => ({
    id: `vehicle_${v.id}`,
    name: v.name,
    description: v.description,
    price: v.unlockCost,
    currency: v.unlockCurrency,
    rarity: (v.vehicleClass === 'A' ? 'legendary' : v.vehicleClass === 'B' ? 'epic' : 'rare') as ShopItem['rarity'],
    type: 'vehicle' as const,
    emoji: '🏎️'
  })),
  // Cosmetic skins
  { id: 'skin_galaxy', name: 'Galaxy Paint', description: 'Cosmic swirl pattern for any vehicle.', price: 1500, currency: 'coins', rarity: 'rare', type: 'skin', emoji: '🌌' },
  { id: 'skin_cherry', name: 'Cherry Blossom', description: 'Elegant sakura petal design.', price: 2500, currency: 'coins', rarity: 'epic', type: 'skin', emoji: '🌸' },
  { id: 'skin_golden', name: 'Royal Gold', description: 'Shimmering gold leaf finish.', price: 100, currency: 'gems', rarity: 'legendary', type: 'skin', emoji: '👑' },
  { id: 'skin_ice', name: 'Ice Crystal', description: 'Frosted crystalline coating.', price: 1800, currency: 'coins', rarity: 'rare', type: 'skin', emoji: '❄️' },
  // Boost trails
  { id: 'trail_rainbow', name: 'Rainbow Trail', description: 'Leave a prismatic trail behind you.', price: 2000, currency: 'coins', rarity: 'epic', type: 'trail', emoji: '🌈' },
  { id: 'trail_sparkle', name: 'Sparkle Dust', description: 'Glittering particles in your wake.', price: 1200, currency: 'coins', rarity: 'rare', type: 'trail', emoji: '✨' },
  { id: 'trail_flame', name: 'Pastel Flame', description: 'Soft flame effect in pastel colors.', price: 150, currency: 'gems', rarity: 'legendary', type: 'trail', emoji: '🔥' },
];

const RARITY_COLORS = {
  common: { bg: 'bg-slate-100', text: 'text-slate-600', border: 'border-slate-200' },
  rare: { bg: 'bg-blue-50', text: 'text-blue-600', border: 'border-blue-200' },
  epic: { bg: 'bg-purple-50', text: 'text-purple-600', border: 'border-purple-200' },
  legendary: { bg: 'bg-amber-50', text: 'text-amber-600', border: 'border-amber-200' },
};

const GEM_PACKS = [
  { id: 'starter', name: 'Starter Pack', gems: 50, coins: 1000, price: '$1.99', badge: 'One-time' },
  { id: 'race', name: 'Race Bundle', gems: 150, coins: 3000, price: '$4.99', badge: 'Popular' },
  { id: 'peak', name: 'Peak Pack', gems: 500, coins: 10000, price: '$14.99', badge: 'Best Value' },
];

export const Shop = ({ onNavigate }: { onNavigate: (path: string) => void }) => {
  const gd = GameDataManager.getInstance();
  const [data, setData] = useState(gd.getData());
  const [activeTab, setActiveTab] = useState<'vehicles' | 'skins' | 'trails' | 'gems'>('vehicles');
  const [toast, setToast] = useState<string | null>(null);

  // Mock fetching items from the API to show integration point
  useEffect(() => {
    const fetchItems = async () => {
        try {
            const items = await apiFetch('/shop/items');
            // The items would typically replace or supplement SHOP_ITEMS.
            // For the sake of this prototype, we're keeping SHOP_ITEMS statically
            // but logging the API response.
            console.log('API Shop Items:', items);
        } catch (e) {
            console.error('Failed to fetch shop items:', e);
        }
    };
    fetchItems();
  }, []);

  useEffect(() => {
    const unsub = gd.subscribe(setData);
    return unsub;
  }, []);

  const showToast = (msg: string) => {
    setToast(msg);
    setTimeout(() => setToast(null), 2000);
  };

  const handlePurchase = async (item: ShopItem) => {
    if (item.type === 'vehicle') {
      const vehicleId = item.id.replace('vehicle_', '');
      const vehicle = VEHICLES.find(v => v.id === vehicleId);
      if (!vehicle) return;
      if ((data.ownedVehicles || []).includes(vehicleId)) {
        showToast('Already owned!');
        return;
      }
      // Example API call to unlock vehicle
      try {
         const result = await apiFetch(`/vehicles/${vehicleId}/unlock`, { method: 'POST' });
         if (result.vehicle) {
             gd.unlockVehicle(vehicleId, vehicle.unlockCost, vehicle.unlockCurrency);
             showToast(`${vehicle.name} purchased!`);
         }
      } catch(e) {
         console.error(e);
         showToast(`Not enough ${vehicle.unlockCurrency}!`);
      }
    } else {
      if (item.currency === 'coins' && data.coins >= item.price) {
        try {
           await apiFetch('/shop/purchase', {
               method: 'POST',
               body: JSON.stringify({ item_id: item.id })
           });
           gd.addCoins(-item.price);
           showToast(`${item.name} purchased!`);
        } catch(e) {
           showToast(`Error: ${e}`);
        }
      } else if (item.currency === 'gems' && (data.gems || 0) >= item.price) {
        gd.addGems(-item.price); // Mock since gem API isn't fully implemented in our mockup server
        showToast(`${item.name} purchased!`);
      } else {
        showToast(`Not enough ${item.currency}!`);
      }
    }
  };

  const filteredItems = SHOP_ITEMS.filter(item => {
    if (activeTab === 'vehicles') return item.type === 'vehicle';
    if (activeTab === 'skins') return item.type === 'skin';
    if (activeTab === 'trails') return item.type === 'trail';
    return false;
  });

  return (
    <main className="h-screen w-full flex flex-col relative z-10 overflow-hidden">
      {/* Header */}
      <div className="flex items-center justify-between p-6 z-20">
        <button
          onClick={() => onNavigate('landing')}
          className="glass-button h-14 px-6 rounded-full font-display uppercase font-black tracking-widest text-sm shadow-xl border-white/80 flex items-center gap-2"
        >
          <ChevronLeft size={18} />
          Back
        </button>

        <div className="flex items-center gap-2">
          <ShoppingBag size={28} className="text-primary" />
          <h1 className="font-display text-3xl font-black text-primary italic">SHOP</h1>
        </div>

        <div className="flex gap-3">
          <div className="glass-panel px-4 py-2 rounded-full flex items-center gap-2">
            <Coins size={16} className="text-amber-500" />
            <span className="font-display font-black text-slate-700">{data.coins?.toLocaleString()}</span>
          </div>
          <div className="glass-panel px-4 py-2 rounded-full flex items-center gap-2">
            <Gem size={16} className="text-purple-500" />
            <span className="font-display font-black text-slate-700">{(data.gems || 0).toLocaleString()}</span>
          </div>
        </div>
      </div>

      {/* Toast */}
      {toast && (
        <motion.div
          initial={{ y: -20, opacity: 0 }}
          animate={{ y: 0, opacity: 1 }}
          className="absolute top-24 left-1/2 -translate-x-1/2 z-50 glass-panel px-6 py-3 rounded-full font-display font-black text-sm text-primary shadow-2xl"
        >
          {toast}
        </motion.div>
      )}

      {/* Tabs */}
      <div className="flex gap-2 px-6 mb-4">
        {(['vehicles', 'skins', 'trails', 'gems'] as const).map(tab => (
          <button
            key={tab}
            onClick={() => setActiveTab(tab)}
            className={`px-5 py-2 rounded-full font-display font-black text-sm uppercase tracking-wider transition-all
              ${activeTab === tab ? 'bg-white shadow-lg text-primary ring-2 ring-pink-300' : 'glass-button text-slate-500 hover:text-slate-700'}
            `}
          >
            {tab === 'vehicles' ? '🏎️' : tab === 'skins' ? '🎨' : tab === 'trails' ? '✨' : '💎'} {tab}
          </button>
        ))}
      </div>

      {/* Content */}
      <div className="flex-1 overflow-y-auto px-6 pb-6">
        {activeTab !== 'gems' ? (
          <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-4xl mx-auto">
            {filteredItems.map((item, i) => {
              const rarityStyle = RARITY_COLORS[item.rarity];
              const isVehicleOwned = item.type === 'vehicle' && (data.ownedVehicles || []).includes(item.id.replace('vehicle_', ''));

              return (
                <motion.div
                  key={item.id}
                  initial={{ y: 20, opacity: 0 }}
                  animate={{ y: 0, opacity: 1 }}
                  transition={{ delay: i * 0.05 }}
                  className={`glass-panel p-5 rounded-2xl relative overflow-hidden ${isVehicleOwned ? 'opacity-60' : ''}`}
                >
                  <div className={`absolute top-0 left-0 w-full h-1 ${rarityStyle.bg.replace('50', '400').replace('bg-', 'bg-')}`}
                    style={{ background: item.rarity === 'legendary' ? 'linear-gradient(90deg, #fbbf24, #f59e0b, #d97706)' :
                             item.rarity === 'epic' ? 'linear-gradient(90deg, #a78bfa, #8b5cf6)' :
                             item.rarity === 'rare' ? 'linear-gradient(90deg, #60a5fa, #3b82f6)' : '#94a3b8' }} />

                  <div className="flex items-start gap-4 mb-3">
                    <span className="text-4xl">{item.emoji}</span>
                    <div className="flex-1">
                      <h3 className="font-display font-black text-slate-800 text-sm">{item.name}</h3>
                      <span className={`text-[10px] font-black uppercase tracking-wider ${rarityStyle.text}`}>{item.rarity}</span>
                    </div>
                  </div>

                  <p className="text-xs text-slate-500 font-bold mb-4">{item.description}</p>

                  {isVehicleOwned ? (
                    <div className="text-center text-xs font-black text-emerald-600 bg-emerald-50 py-2 rounded-lg">
                      ✓ Owned
                    </div>
                  ) : (
                    <button
                      onClick={() => handlePurchase(item)}
                      className="glass-button w-full py-2.5 rounded-xl text-sm font-black flex items-center justify-center gap-2 hover:bg-white/80 transition-all"
                    >
                      {item.currency === 'coins' ? <Coins size={14} className="text-amber-500" /> : <Gem size={14} className="text-purple-500" />}
                      {item.price.toLocaleString()} {item.currency === 'coins' ? '🪙' : '💎'}
                    </button>
                  )}
                </motion.div>
              );
            })}
          </div>
        ) : (
          /* Gem Packs */
          <div className="grid grid-cols-1 sm:grid-cols-3 gap-6 max-w-3xl mx-auto">
            {GEM_PACKS.map((pack, i) => (
              <motion.div
                key={pack.id}
                initial={{ y: 20, opacity: 0 }}
                animate={{ y: 0, opacity: 1 }}
                transition={{ delay: i * 0.1 }}
                className="glass-panel p-6 rounded-2xl text-center relative overflow-hidden"
              >
                {pack.badge && (
                  <div className="absolute top-0 right-0 bg-pink-500 text-white text-[10px] font-black px-3 py-1 rounded-bl-xl">
                    {pack.badge}
                  </div>
                )}
                <div className="text-5xl mb-3">💎</div>
                <h3 className="font-display font-black text-slate-800 text-lg mb-1">{pack.name}</h3>
                <div className="flex flex-col gap-1 mb-4">
                  <span className="text-sm font-bold text-purple-600">{pack.gems} Gems</span>
                  <span className="text-sm font-bold text-amber-600">+ {pack.coins.toLocaleString()} Coins</span>
                </div>
                <button className="glass-button-primary w-full py-3 rounded-xl font-black text-lg">
                  {pack.price}
                </button>
              </motion.div>
            ))}
          </div>
        )}
      </div>
    </main>
  );
};
